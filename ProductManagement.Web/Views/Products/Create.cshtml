@model ProductManagement.Domain.Entities.Product
@{
    ViewData["Title"] = "New Product";
}

<h1>New Product</h1>

<form method="post" action="/Products/Create" class="form">
    @Html.AntiForgeryToken()

    <label>
        Name
        <input name="Name" required maxlength="100" autofocus />
    </label>

    <label>
        Description
        <textarea name="Description" maxlength="500" rows="4"></textarea>
    </label>

    <label>
        Price (USD)
        <input name="Price" type="number" step="0.01" min="0" required />
    </label>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/Products" class="btn">Cancel</a>
    </div>
</form>