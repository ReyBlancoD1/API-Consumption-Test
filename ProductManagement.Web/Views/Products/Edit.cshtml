@model ProductManagement.Domain.Entities.Product
@{
    ViewData["Title"] = "Edit Product";
}

<h1>Edit Product #@Model.Id</h1>

<form method="post" action="/Products/Edit/@Model.Id" class="form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <label>
        Name
        <input name="Name" value="@Model.Name" required maxlength="100" />
    </label>

    <label>
        Description
        <textarea name="Description" maxlength="500" rows="4">@Model.Description</textarea>
    </label>

    <label>
        Price (USD)
        <input name="Price" type="number" step="0.01" min="0" value="@Model.Price" required />
    </label>

    <div class="readonly-info">
        <small>Created: @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</small>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a href="/Products" class="btn">Cancel</a>
    </div>
</form>